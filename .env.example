# Copy this file to .env and fill in your own values.

# A long, random string used to encrypt login sessions.
# You can generate one at https://www.uuidgenerator.net/ or by running:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change_this_to_a_long_random_string

# The author/admin login. Change these before deploying!
ADMIN_USERNAME=author
ADMIN_PASSWORD=change_this_password

# Port the server runs on (most hosts set this automatically)
PORT=3000

# Display name shown on the site
SITE_TITLE=My Novel Blog
